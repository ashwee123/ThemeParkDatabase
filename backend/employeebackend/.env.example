# Copy to .env and fill in for your MySQL instance (e.g. Azure Database for MySQL).

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=newthemepark

# For Azure MySQL, try: MYSQL_SSL=azure (uses TLS; rejectUnauthorized=false for common dev setups)
# MYSQL_SSL=true
# MYSQL_SSL_REJECT_UNAUTHORIZED=false

PORT=3000

# Browser CORS when the front end is on another origin (default * for local dev)
# CORS_ORIGIN=http://localhost:3000
