{
  "$schema": "https://openapi.vercel.sh/vercel.json",

  "rewrites": [
    {
      "source": "/styles.css",
      "destination": "/backend/hrmanagerbackend/public/styles.css"
    },
    {
      "source": "/app.js",
      "destination": "/backend/hrmanagerbackend/public/app.js"
    },

    {
      "source": "/hr",
      "destination": "/backend/hrmanagerbackend/public/index.html"
    },

    {
      "source": "/",
      "destination": "/backend/hrmanagerbackend/public/login.html"
    },

    {
      "source": "^/(login|managers|employees|assign-manager|maintenance|performance|report)(/.*)?$",
      "destination": "/api/server?orig=/$1$2"
    }
  ]
}
