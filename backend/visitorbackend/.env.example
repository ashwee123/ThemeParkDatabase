# Copy to .env and update values for your environment

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=yourpassword
DB_NAME=newthemepark
DB_SSL=false

# Used to sign visitor JWT tokens
JWT_SECRET=change-this-secret

# Visitor portal server
VISITOR_PORT=3002

# Frontend origin for CORS (Render frontend URL)
FRONTEND_URL=*

# Password hashing cost
PBKDF2_ITERATIONS=120000

